{
  "npmClient": "yarn",
  "packages": [
    "packages/*"
  ],
  "version": "independent",
  "command": {
    "version": {
      "ignoreChanges": [
        "**/.npmignore",
        "**/CHANGELOG.md",
        "**/documentation.mdx",
        "**/index.stories.js",
        "**/vite.config.js"
      ]
    },
    "publish": {
      "registry": "https://registry.npmjs.org"
    }
  },
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "useWorkspaces": false
}
